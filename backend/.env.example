APP_NAME=PetPosture
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# DATABASE
# Local: use SQLite. Production (Railway): use MySQL with the vars below.
# ---------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=petposture
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ---------------------------------------------------------------------------
# SANCTUM
# Production: set to your Vercel frontend domain (no https://, no trailing slash)
# e.g. SANCTUM_STATEFUL_DOMAINS=petposture.vercel.app
# ---------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# ---------------------------------------------------------------------------
# STRIPE
# 1. Copy publishable key  → STRIPE_KEY
# 2. Copy secret key       → STRIPE_SECRET
# 3. Register webhook URL in Stripe Dashboard:
#    https://dashboard.stripe.com/webhooks
#    Endpoint URL: https://<your-railway-domain>/api/webhooks/stripe
#    Events to listen: payment_intent.succeeded, payment_intent.payment_failed, payment_intent.canceled
# 4. Copy webhook signing secret → STRIPE_WEBHOOK_SECRET
# ---------------------------------------------------------------------------
STRIPE_KEY=pk_live_...
STRIPE_SECRET=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TAX_DEFAULT_PRODUCT_TAX_CODE=txcd_99999999

# Slack (optional, for admin notifications)
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

# ---------------------------------------------------------------------------
# MAIL  (production)
# Recommended: use Resend (https://resend.com) or Mailgun.
# Resend example:
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.resend.com
#   MAIL_PORT=465
#   MAIL_USERNAME=resend
#   MAIL_PASSWORD=re_...
#   MAIL_SCHEME=ssl
#   MAIL_FROM_ADDRESS=orders@petposture.com
#   MAIL_FROM_NAME=PetPosture
#
# Local development: MAIL_MAILER=log (emails go to storage/logs/laravel.log)
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="orders@petposture.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
